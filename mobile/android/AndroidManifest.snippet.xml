<!--
  Merge these entries into mobile/android/app/src/main/AndroidManifest.xml
  (generated by `react-native init`), inside the <manifest> tag and before
  <application>.

  - BLUETOOTH_ADVERTISE / BLUETOOTH_CONNECT: required on Android 12+ (API 31+)
    to run a GATT server (peripheral role) and accept connections.
  - BLUETOOTH_SCAN: required to discover/verify the desktop host is nearby.
  - ACCESS_FINE_LOCATION: required on Android <12 for any BLE scan/advertise.
  - usesPermissionFlags="neverForLocation" tells Android 12+ this app does not
    derive physical location from BLE scan results.
-->
<uses-permission android:name="android.permission.BLUETOOTH_ADVERTISE" />
<uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
<uses-permission
    android:name="android.permission.BLUETOOTH_SCAN"
    android:usesPermissionFlags="neverForLocation" />
<uses-permission
    android:name="android.permission.ACCESS_FINE_LOCATION"
    android:maxSdkVersion="30" />

<!-- Declares that this app requires BLE hardware to function. -->
<uses-feature
    android:name="android.hardware.bluetooth_le"
    android:required="true" />
