<!--
  Merge these keys into mobile/ios/StreamDeckRemote/Info.plist (generated by
  `react-native init`), as children of the top-level <dict>.

  Both keys are required for apps that advertise/run a BLE peripheral (GATT
  server) on iOS - NSBluetoothAlwaysUsageDescription covers Bluetooth usage in
  general, NSBluetoothPeripheralUsageDescription specifically covers acting as
  a peripheral (advertising services to other devices).
-->
<key>NSBluetoothAlwaysUsageDescription</key>
<string>Stream Deck Remote uses Bluetooth to send button presses to the Stream Deck Host app on your computer.</string>
<key>NSBluetoothPeripheralUsageDescription</key>
<string>Stream Deck Remote advertises itself over Bluetooth so the Stream Deck Host app on your computer can connect and receive button presses.</string>

<!-- Allow BLE peripheral mode to keep running briefly in the background. -->
<key>UIBackgroundModes</key>
<array>
    <string>bluetooth-peripheral</string>
</array>
